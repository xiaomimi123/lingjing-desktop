{
  "name": "lingjing-desktop",
  "productName": "灵境",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --env-file=.env server/index.js",
    "dev:all": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"vite\" \"node --env-file=.env server/index.js\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --env-file=.env server/index.js",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n \"frontend,electron\" -c \"blue,magenta\" \"vite\" \"wait-on tcp:3001 && electron .\"",
    "electron:build": "vite build",
    "dist:mac": "npm run electron:build && electron-builder --mac",
    "dist:win": "npm run electron:build && electron-builder --win",
    "dist:win:dir": "npm run electron:build && electron-builder --win --dir",
    "run:packed": "release/win-unpacked/Lingjing.exe",
    "rebuild:native": "cd node_modules/better-sqlite3 && ../.bin/prebuild-install --runtime=electron --target=36.9.5 --arch=x64",
    "test:e2e": "node --env-file-if-exists=.env.test ./node_modules/.bin/playwright test",
    "test:e2e:headed": "node --env-file-if-exists=.env.test ./node_modules/.bin/playwright test --headed",
    "test:e2e:ui": "node --env-file-if-exists=.env.test ./node_modules/.bin/playwright test --ui",
    "test:report": "playwright show-report"
  },
  "build": {
    "appId": "com.lingjing.desktop",
    "productName": "灵境",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "asar": false,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      {
        "from": "node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!**/test/**",
          "!**/tests/**",
          "!**/*.md",
          "!**/*.markdown",
          "!**/.bin/**",
          "!**/CHANGELOG*",
          "!**/HISTORY*"
        ]
      }
    ],
    "extraResources": [
      "data/**/*",
      {
        "from": "resources/openclaw",
        "to": "openclaw",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/hermes",
        "to": "hermes",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "灵境"
    },
    "win": {
      "executableName": "Lingjing",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "灵境",
      "artifactName": "Lingjing-Setup-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "xiaomimi123",
      "repo": "lingjing-desktop",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@noble/ed25519": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@vicons/ionicons5": "^0.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "check-disk-space": "^3.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "edge-tts-client": "^1.0.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.44",
    "markdown-it": "^14.1.1",
    "multer": "^2.0.2",
    "naive-ui": "^2.43.2",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^3.11.174",
    "pinia": "^3.0.4",
    "ssh2": "^1.17.0",
    "tar": "^7.5.11",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.25",
    "vue-i18n": "^9.0.0",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "electron": "^36.9.5",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "eventsource": "^4.1.0",
    "happy-dom": "^20.7.0",
    "playwright": "^1.58.2",
    "prebuild-install": "^7.1.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5",
    "wait-on": "^8.0.5"
  }
}
